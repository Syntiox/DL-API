# ════════════════════════════════════════════════════
#  Syntiox DL API — Local Environment Variables
#  Copy this file → rename to .env → fill in values
#  DO NOT commit .env to git!
# ════════════════════════════════════════════════════

# ── Security Keys ────────────────────────────────────
JWT_SECRET=change-me-in-production
API_SECRET=change-me-in-production

# ── YouTube PO Token (Optional — only if bgutil not running) ─────────────────
# Get from: https://github.com/YunzheZJU/youtube-po-token-generator
# or leave blank if using bgutil server (Docker)
YT_PO_TOKEN=
YT_VISITOR_DATA=

# ── YouTube Cookies (base64 encoded cookies.txt) ─────────────────────────────
# Run locally: POST http://localhost:8000/cookies/refresh?browser=chrome
# Then encode: [Convert]::ToBase64String([IO.File]::ReadAllBytes("cookies.txt")) | clip
# Paste result here:
YT_COOKIES=

# ── External PO Token Provider (Optional REST API) ───────────────────────────
# If you have a separate PO token server running:
POT_PROVIDER_URL=

# ── bgutil PO Token Server URL ───────────────────────────────────────────────
# Default: http://localhost:4416 (auto-started by Docker startup.sh)
# Change only if bgutil runs on a different host/port
BGU_BASE_URL=http://localhost:4416
